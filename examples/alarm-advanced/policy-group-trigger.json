{
  "Name": "advanced-group-trigger",
  "AlarmTargets": [
    {
      "LogsetId": "logset-xxx",
      "TopicId": "topic-xxx",
      "Query": "host:\"a.example.com\" AND status>=500 | select request_uri, count(*) as error_count group by request_uri",
      "Number": 1,
      "StartTimeOffset": -5,
      "EndTimeOffset": 0,
      "SyntaxRule": 1
    }
  ],
  "MonitorTime": {"Type": "Period", "Time": 5},
  "Condition": "$1.error_count > 100",
  "GroupTriggerStatus": true,
  "GroupTriggerCondition": ["request_uri"],
  "TriggerCount": 1,
  "AlarmPeriod": 15,
  "AlarmLevel": 1,
  "Status": true,
  "MonitorObjectType": 0
}
